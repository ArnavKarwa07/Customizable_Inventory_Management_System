# Frontend Environment Template - Copy to .env.example

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENVIRONMENT=development

# App Information
NEXT_PUBLIC_APP_NAME=Customizable Inventory Management
NEXT_PUBLIC_APP_DESCRIPTION=Professional inventory management system

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=false

# Optional: Error Tracking
NEXT_PUBLIC_SENTRY_DSN=

# Optional: Analytics
NEXT_PUBLIC_GA_ID=

# Session and Auth
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=60
NEXT_PUBLIC_TOKEN_REFRESH_INTERVAL_MINUTES=55

# UI Configuration
NEXT_PUBLIC_DEFAULT_THEME=light
NEXT_PUBLIC_ITEMS_PER_PAGE=50
