# Backend Environment Template - Copy to .env and update

# Database
DATABASE_URL=sqlite:///./inventory.db
# For PostgreSQL: postgresql://user:password@localhost:5432/inventory

# Server Configuration
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@inventoryapp.com

# Application Settings
APP_NAME=Customizable Inventory Management System
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# File Upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIRECTORY=./uploads

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Timezone
TIMEZONE=UTC
